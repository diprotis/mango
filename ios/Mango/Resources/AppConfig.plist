<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Baked-in backend endpoints. Fill these after deploying (or let CI inject
	     them). Leave empty to keep that environment "not configured". -->
	<key>BetaAPIURL</key>
	<string></string>
	<key>ProdAPIURL</key>
	<string></string>

	<!-- Cognito Hosted-UI / OAuth config (spec 0003). Fill these after deploying
	     the user pool domain + app client. Leave empty to keep sign-in disabled
	     (the app still works fully offline). The redirect URI is
	     <CognitoRedirectScheme>://callback and the scheme must also be registered
	     as a URL Type in the app target's Info settings. -->
	<key>CognitoDomain</key>
	<string></string>
	<key>CognitoClientId</key>
	<string></string>
	<key>CognitoRegion</key>
	<string></string>
	<key>CognitoRedirectScheme</key>
	<string></string>
</dict>
</plist>
